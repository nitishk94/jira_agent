# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=agent@example.com
JIRA_API_TOKEN=

# GitHub
GITHUB_TOKEN=

# Vertex AI (Gemini 3 Flash)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-3-flash-preview
# Optional: path to a service account key JSON. Leave unset to use
# `gcloud auth application-default login` (ADC) instead. Never commit the
# key file itself — see config/service-account.json in .gitignore.
GOOGLE_APPLICATION_CREDENTIALS=

# Client modes: mock | live. Mock uses in-memory fixtures, no network calls.
JIRA_CLIENT_MODE=mock
GITHUB_CLIENT_MODE=mock

# CocoIndex MCP server. Leave empty to use the built-in plain-text search stub.
COCOINDEX_MCP_URL=

# Run log storage. Leave RUN_LOG_GCS_BUCKET empty to write local-only.
RUN_LOG_GCS_BUCKET=
RUN_LOG_LOCAL_DIR=./logs

# Orchestration
POLL_INTERVAL_MINUTES=5
MAX_CONCURRENT_TICKETS=3
MAX_FIX_ATTEMPTS=3

# Path to the projects.yaml mapping file
PROJECTS_CONFIG_PATH=./config/projects.yaml

# Local bare-mirror cache for repo checkouts
REPO_MIRROR_DIR=./.repo-mirrors
